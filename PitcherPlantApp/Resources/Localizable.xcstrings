    "audit.summary.base": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Completed: %d documents / %d images / %d historical fingerprints, took %@ seconds"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "完成：%d 个文档 / %d 张图片 / %d 条历史指纹，耗时 %@ 秒"
          }
        }
      }
    },
    "audit.summary.recall": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "%@; candidate recall %d/%d pairs, took %@ms"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "%@；候选召回 %d/%d 对，耗时 %@ms"
          }
        }
      }
    },
    "audit.summary.recallSkippedBuckets": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "%@; warning: candidate recall skipped %d oversized buckets, so highly homogeneous samples may be underreported"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "%@；注意：候选召回跳过 %d 个过大 bucket，可能漏报高度同质化样本"
          }
        }
      }
    },
