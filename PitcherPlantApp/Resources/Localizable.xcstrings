    "settings.termsOfUseBody": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "PitcherPlant is designed to assist security competition WriteUP review. App output is decision support for human reviewers, and final decisions should still consider competition rules, context, and manual verification. Do not use this app to process data you are not authorized to review."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "PitcherPlant 用于辅助安全竞赛 WriteUP 审查。应用输出只作为人工复核依据，最终判断仍应结合比赛规则、上下文和人工确认。请不要用本应用处理你无权审查的数据。"
          }
        }
      }
    },
