    "settings.privacyPolicy": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Privacy Policy"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "隐私政策"
          }
        }
      }
    },
    "settings.privacyPolicyBody": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "PitcherPlant processes audit data locally by default and stores databases, reports, and configuration in the local workspace. Unless you manually check for updates, submit an issue, open an external link, or request Audit Assistant analysis in API Key mode, the app does not upload your audit content. When you use the Audit Assistant external API, the app may send evidence summaries, evidence details, or full context to the external models provider you configure according to the Shared Data setting; API keys are stored only in macOS Keychain."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "PitcherPlant 默认在本机处理审计数据，并把数据库、报告和配置保存到本机工作区。除非你主动打开更新检查、提交错误报告、访问外部链接，或在 API Key 模式下请求审计助手分析，应用不会主动上传你的审计内容。使用审计助手外部 API 时，应用可能会按“外发数据”设置，把证据摘要、证据详情或完整上下文发送给你配置的外部模型提供方；API Key 只保存到 macOS Keychain。"
          }
        }
      }
    },
