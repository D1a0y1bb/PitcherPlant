    "settings.helpCenter": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Help Center"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "帮助中心"
          }
        }
      }
    },
    "settings.helpCenterBody": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "PitcherPlant is a local-first macOS WriteUP audit workstation. A typical flow is choosing an audit directory, importing submission packages, running audits, reviewing evidence in Reports, and exporting results. Reports, evidence, fingerprints, and whitelist data are stored in the local workspace database."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "PitcherPlant 是本地优先的 macOS WriteUP 审计工作台。常用流程是选择审计目录，导入提交包，运行审计，在报告中心复核证据并导出结果。报告、证据、指纹和白名单数据保存在本机工作区数据库中。"
          }
        }
      }
    },
